\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}LLM Density Drops Where Human Residuals Are Large}{13}{subsection.6.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces LLM density around human rationales vs.\ reconstruction error (sliding window). Green (left axis): mean distance to 50 nearest LLM neighbors---increases monotonically ($r = 0.969$). Orange (right axis): mean LLM neighbors within fixed radius---decreases ($r = -0.527$). Human rationales that occupy the extra dimensions are in LLM-sparse regions of embedding space.}}{13}{figure.caption.23}\protected@file@percent }
\newlabel{fig:freq_geom_binned}{{10}{13}{LLM density around human rationales vs.\ reconstruction error (sliding window). Green (left axis): mean distance to 50 nearest LLM neighbors---increases monotonically ($r = 0.969$). Orange (right axis): mean LLM neighbors within fixed radius---decreases ($r = -0.527$). Human rationales that occupy the extra dimensions are in LLM-sparse regions of embedding space}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Per-rationale density ratio (LLM distance / human distance) vs.\ reconstruction error. Each point is one of 10,826 human rationales. The trend line shows $r = 0.543$; at the bin level, $r = 0.988$.}}{14}{figure.caption.24}\protected@file@percent }
\newlabel{fig:freq_geom_scatter}{{11}{14}{Per-rationale density ratio (LLM distance / human distance) vs.\ reconstruction error. Each point is one of 10,826 human rationales. The trend line shows $r = 0.543$; at the bin level, $r = 0.988$}{figure.caption.24}{}}
