\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Cluster entropy: joint (left) vs.\ per-source (right) clustering. Joint clustering artificially depresses human entropy; per-source clustering shows human and LLM entropy are nearly identical.}}{18}{figure.caption.35}\protected@file@percent }
\newlabel{fig:joint_vs_persource}{{16}{18}{Cluster entropy: joint (left) vs.\ per-source (right) clustering. Joint clustering artificially depresses human entropy; per-source clustering shows human and LLM entropy are nearly identical}{figure.caption.35}{}}
