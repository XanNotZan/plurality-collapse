\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Value diversity gradient (Kaleido, clustered labels, sliding window $w = 200$, step $= 50$). Each point is a bin of 200 rationales, ordered left-to-right by increasing reconstruction error. The green line (left axis) shows unique moral value clusters per bin; the orange line (right axis) shows Shannon entropy. Both increase monotonically ($r = 0.897$, $p < 0.0001$).}}{9}{figure.caption.15}\protected@file@percent }
\newlabel{fig:gradient_kaleido}{{6}{9}{Value diversity gradient (Kaleido, clustered labels, sliding window $w = 200$, step $= 50$). Each point is a bin of 200 rationales, ordered left-to-right by increasing reconstruction error. The green line (left axis) shows unique moral value clusters per bin; the orange line (right axis) shows Shannon entropy. Both increase monotonically ($r = 0.897$, $p < 0.0001$)}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Value diversity gradient for LLM rationales under human principal components (clustered labels, sliding window). Rationales with larger residuals invoke more diverse moral values ($r = 0.823$).}}{10}{figure.caption.16}\protected@file@percent }
\newlabel{fig:gradient_llm}{{7}{10}{Value diversity gradient for LLM rationales under human principal components (clustered labels, sliding window). Rationales with larger residuals invoke more diverse moral values ($r = 0.823$)}{figure.caption.16}{}}
